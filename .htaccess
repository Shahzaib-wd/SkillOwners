# Skill Owners - Security and Friendly URLs
# ===============================================

# 1. Basic Security
Options -Indexes
ServerSignature Off

# 2. Security Headers
<IfModule mod_headers.c>
    Header set X-Frame-Options "SAMEORIGIN"
    Header set X-XSS-Protection "1; mode=block"
    Header set X-Content-Type-Options "nosniff"
    Header set Referrer-Policy "strict-origin-when-cross-origin"
</IfModule>

# 3. URL Rewriting (PHP Hiding)
<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /skill_owners/

    # Basic rewrite rules for existing files
    RewriteCond %{REQUEST_FILENAME} -f [OR]
    RewriteCond %{REQUEST_FILENAME} -d
    RewriteRule ^ - [L]

    # Admin sub-pages (Handles /alpha/page)
    RewriteRule ^alpha/([^/.]+)/?$ dashboard/alpha/$1.php [L]
    
    # Direct file access in admin (for relative links)
    RewriteRule ^alpha/(.+\.php)$ dashboard/alpha/$1 [L]
    
    # Admin shortcut (/alpha)
    RewriteRule ^alpha/?$ dashboard/alpha/index.php [L]

    # Friendly Blog Routes
    RewriteRule ^blog/([^/.]+)/?$ blog_post.php?slug=$1 [L,QSA]
    RewriteRule ^blog_post/([0-9]+)/?$ blog_post.php?id=$1 [L,QSA]

    # Standard pages (e.g., /services -> services.php)
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME}\.php -f
    RewriteRule ^([^/]+)/?$ $1.php [L]
</IfModule>

# 4. Error Handling (Optional but professional)
ErrorDocument 404 /skill_owners/index.php

